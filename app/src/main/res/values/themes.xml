<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="ShapeAppearance.Travelo.Card" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.Travelo.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.Travelo.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Theme.Travelo" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/travelo_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/travelo_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/travelo_on_primary_container</item>

        <item name="colorSecondary">@color/travelo_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/travelo_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/travelo_on_secondary_container</item>

        <item name="colorTertiary">@color/travelo_tertiary</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/travelo_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/travelo_on_tertiary_container</item>

        <item name="colorError">@color/travelo_error</item>
        <item name="android:colorBackground">@color/travelo_background</item>
        <item name="colorSurface">@color/travelo_surface</item>
        <item name="colorSurfaceVariant">@color/travelo_surface_variant</item>
        <item name="colorOutline">@color/travelo_outline</item>
        <item name="colorOnSurface">@color/travelo_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/travelo_on_surface_variant</item>

        <item name="shapeAppearanceCornerLarge">@style/ShapeAppearance.Travelo.Card</item>
        <item name="materialButtonStyle">@style/Widget.Travelo.Button</item>
        <item name="android:statusBarColor">@color/travelo_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>